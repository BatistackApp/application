{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "laravel/livewire-starter-kit",
    "type": "project",
    "description": "The official Laravel starter kit for Livewire.",
    "keywords": ["laravel", "framework"],
    "license": "MIT",
    "require": {
        "php": "^8.3",
        "ext-fileinfo": "*",
        "achyutn/filament-log-viewer": "^2.3",
        "ariefng/filament-calculator": "^1.2",
        "batistackapp/activity-log": "^1.0@alpha",
        "batistackapp/filament-map-picker": "^1.0",
        "batistackapp/progress-stepper": "^1.0",
        "batistackapp/weather-widget": "^1.0",
        "bezhansalleh/filament-panel-switch": "^3.1",
        "croustibat/filament-jobs-monitor": "^4.3",
        "devletes/filament-progress-bar": "^1.0",
        "filament/filament": "^5.0",
        "filament/spatie-laravel-media-library-plugin": "^5.4",
        "guava/calendar": "^3.1",
        "guava/filament-knowledge-base": "dev-l13-compatibility",
        "harvirsidhu/filament-cards": "^1.0",
        "hydrat/filament-table-layout-toggle": "4.0",
        "laravel-lang/common": "*",
        "laravel/fortify": "^1.34",
        "laravel/framework": "^13.0",
        "laravel/tinker": "^3.0",
        "livewire/flux": "^2.12.0",
        "livewire/livewire": "^4.1",
        "marcelorodrigo/filament-barcode-scanner-field": "^1.1",
        "nakanakaii/filament-countries": "^1.0",
        "nben/filament-record-nav": "^2.0",
        "opcodesio/log-viewer": "^3.24",
        "qalainau/filament-inbox": "^1.0",
        "saade/filament-autograph": "^4.1",
        "spatie/browsershot": "^5.2",
        "spatie/laravel-activitylog": "^5.0",
        "spatie/laravel-medialibrary": "^11.21",
        "tapp/filament-progress-bar-column": "^1.0",
        "tinusg/filament-company-logo-column": "^1.0",
        "tonegabes/filament-better-options": "^1.3",
        "tonegabes/filament-phosphor-icons": "^1.3",
        "zvizvi/user-fields": "^0.0.4"
    },
    "require-dev": {
        "fakerphp/faker": "^1.24",
        "laravel/boost": "*",
        "laravel/pail": "^1.2.5",
        "laravel/pint": "^1.27",
        "laravel/sail": "^1.53",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.9",
        "pestphp/pest": "^4.4",
        "pestphp/pest-plugin-laravel": "^4.1"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "setup": [
            "composer install",
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\"",
            "@php artisan key:generate",
            "@php artisan migrate --force",
            "npm install",
            "npm run build"
        ],
        "dev": [
            "Composer\\Config::disableProcessTimeout",
            "npx concurrently -c \"#93c5fd,#c4b5fd,#fdba74\" \"php artisan serve\" \"php artisan queue:listen --tries=1\" \"npm run dev\" --names='server,queue,vite'"
        ],
        "lint": [
            "pint --parallel"
        ],
        "lint:check": [
            "pint --parallel --test"
        ],
        "ci:check": [
            "Composer\\Config::disableProcessTimeout",
            "@test"
        ],
        "test": [
            "@php artisan config:clear --ansi",
            "@lint:check",
            "@php artisan test"
        ],
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi",
            "@php artisan filament:upgrade"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force",
            "@php artisan boost:update --ansi"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi",
            "@php -r \"file_exists('database/database.sqlite') || touch('database/database.sqlite');\"",
            "@php artisan migrate --graceful --ansi"
        ],
        "pre-package-uninstall": [
            "Illuminate\\Foundation\\ComposerScripts::prePackageUninstall"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        }
    },
    "minimum-stability": "alpha",
    "prefer-stable": true,
    "repositories": [
        {
            "type": "vcs",
            "url": "https://github.com/laravel-shift/filament-knowledge-base.git"
        }
    ]
}
